{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "services-route": {
        "ClusterId": "services-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/services/{**catch-all}"
        },
        "Metadata": {
          "ResiliencePolicy": "DefaultStrategy"
        }
      },
      "offices-route": {
        "ClusterId": "offices-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/offices/{**catch-all}"
        },
        "Metadata": {
          "ResiliencePolicy": "DefaultStrategy"
        }
      },
      "documents-route": {
        "ClusterId": "documents-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/documents/{**catch-all}"
        },
        "Metadata": {
          "ResiliencePolicy": "DefaultStrategy"
        }
      },
      "appointments-route": {
        "ClusterId": "appointments-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/appointments/{**catch-all}"
        },
        "Metadata": {
          "ResiliencePolicy": "DefaultStrategy"
        }
      }
    },
    "Clusters": {
      "services-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:8002" },
          "destination2": { "Address": "https://localhost:8003" }
        }
      },
      "offices-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:8004" },
          "destination2": { "Address": "https://localhost:8005" }
        }
      },
      "documents-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:8008" },
          "destination2": { "Address": "https://localhost:8009" }
        }
      },
      "appointments-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:8010" },
          "destination2": { "Address": "https://localhost:8011" }
        }
      }
    }
  }
}
